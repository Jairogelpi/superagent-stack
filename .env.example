BASE_DOMAIN=example.com
ACME_EMAIL=you@example.com

# URLs reales de tus motores
OPENCLAW_UPSTREAM=http://host.docker.internal:18789
OPENHANDS_UPSTREAM=http://host.docker.internal:3000
DEERFLOW_UPSTREAM=http://host.docker.internal:2026

# Hostnames públicos
OPENCLAW_HOST=claw.example.com
OPENHANDS_HOST=code.example.com
DEERFLOW_HOST=lab.example.com
N8N_HOST=flow.example.com
ROUTER_HOST=router.example.com

# Router
ROUTER_PORT=8080
ROUTER_DEFAULT_TARGET=openclaw

# n8n
N8N_IMAGE=docker.n8n.io/n8nio/n8n:latest
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me
GENERIC_TIMEZONE=Europe/Madrid

# Kilo / Xiaomi
KILO_API_KEY=replace_me
DEFAULT_REASONING_MODEL=xiaomi/mimo-v2-pro:free
DEFAULT_MULTIMODAL_MODEL=xiaomi/mimo-v2-omni:free
DEFAULT_FAST_MODEL=xiaomi/mimo-v2-flash
